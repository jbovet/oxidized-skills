# oxidized-agentic-audit configuration
# Copy this file to oxidized-agentic-audit.toml and customize as needed.

[allowlist]
# Registries that are approved for package installs
registries = [
    "registry.npmjs.org",
    "pypi.org",
    "files.pythonhosted.org",
]

# Domains approved for outbound HTTP calls in scripts
domains = [
    "registry.npmjs.org",
    "npmjs.org",
    "github.com",
    "githubusercontent.com",
    "pypi.org",
]

[strict]
# Treat warnings as errors (same as --strict CLI flag)
enabled = false

[scanners]
# Enable or disable individual scanners.
# All scanners are enabled by default.

# External-tool scanners (require the tool on PATH)
shellcheck = true       # shell script linting via shellcheck
semgrep = true          # static analysis via semgrep
secrets = true          # secret/credential detection via gitleaks

# Built-in scanners — shared by both skill and agent audits
prompt = true           # prompt injection pattern detection
bash_patterns = true    # dangerous bash anti-patterns
typescript = true       # dangerous TypeScript/JavaScript patterns
package_install = true  # unsafe package installation patterns

# Built-in scanners — skill audits only (audit / audit-all)
frontmatter = true      # SKILL.md frontmatter validation

# Built-in scanners — agent audits only (audit-agent / audit-all-agents)
agent_frontmatter = true  # AGENT.md frontmatter validation

[semgrep]
# Path to local rules (e.g., "semgrep.yml"). If omitted, looks for 
# semgrep.yml or .semgrep.yml in the current directory.
# config = "semgrep.yml"

# Whether to send metrics to semgrep.dev (default: false)
metrics = false

# Whether to check for updates (default: false)
version_check = false
